# Copy this file to .env.local and fill in the values. Do NOT commit .env.local.

# --- Supabase ---
# URL of your Supabase project (public; safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Anon key — respects Row Level Security, safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key — bypasses RLS. SERVER ONLY. Never ship to the browser.
# Used by NextAuth signIn / JWT callbacks and the admin API routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- NextAuth ---
# Canonical URL of this deployment (e.g. https://calculator.yourcompany.com)
NEXTAUTH_URL=http://localhost:3000
# Random 32+ char string. Generate with: `openssl rand -base64 32`
NEXTAUTH_SECRET=your-random-secret
# Optional: set to "true" to force NextAuth debug logging on in production
# NEXTAUTH_DEBUG=false

# --- Google OAuth ---
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: $NEXTAUTH_URL/api/auth/callback/google
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# --- Allowlist ---
# Comma-separated email domains allowed to sign in. Users must ALSO be in the
# Supabase `allowed_users` table with is_active=true. Whitespace is trimmed.
ALLOWED_DOMAINS=encorelm.com

# --- Google Maps (server-side only) ---
# Used by geocoding, distance matrix, directions, and the static-map proxy.
# Restrict to HTTP referrers or API-only in Google Cloud Console.
GOOGLE_MAPS_API_KEY=your-maps-key
